 counts\n","def get_kmer_counts(seq, k=5):\n","    counts = {}\n","    for i in range(len(seq)-k+1):\n","        kmer = seq[i:i+k].upper()\n","        counts[kmer] = counts.get(kmer,0)+1\n","    return counts\n","\n","k = 5\n","kmer_dicts = [get_kmer_counts(seq, k) for seq in df['sequence']]\n","vec = DictVectorizer(sparse=False)\n","X_kmer = vec.fit_transform(kmer_dicts)\n","print(f\"k-mer feature shape: {X_kmer.shape}\")\n","\n","# 2b. Flattened one-hot encoding\n","def one_hot_flat(seq):\n","    mapping = {'A':0,'C':1,'G':2,'T':3}\n","    seq_int = [mapping.get(c,0) for c in seq]\n","    onehot = np.eye(4)[seq_int]  # shape (seq_len, 4)\n","    return onehot.flatten()\n","\n","X_oh = np.array([one_hot_flat(seq) for seq in df['sequence']])\n","print(f\"One-hot flattened feature shape: {X_oh.shape}\")\n","\n","# 2c. Concatenate both encodings (optional)\n","X = np.hstack([X_kmer, X_oh])\n","y = df['label'].values\n","print(f\"Combined feature shape: {X.shape}\")\n","\n","# -------------------- Step 3: Train/test split --------------------\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# -------------------- Step 4: Train XGBoost --------------------\n","clf = xgb.XGBClassifier(\n","    n_estimators=500,\n","    max_depth=6,\n","    learning_rate=0.05,\n","    subsample=0.8,\n","    colsample_bytree=0.8,\n","    use_label_encoder=False,\n","    eval_metric='logloss',\n","    random_state=42\n",")\n","\n","clf.fit(X_train, y_train)\n","\n","# -------------------- Step 5: Evaluate --------------------\n","y_pred = clf.predict(X_test)\n","acc = accuracy_score(y_test, y_pred)\n","print(f\"Test accuracy: {acc:.4f}\")\n","print(\"\\nClassification report:\")\n","print(classification_report(y_test, y_pred, digits=4))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"QsgjiZ2okaCB","executionInfo":{"status":"ok","timestamp":1764956247980,"user_tz":360,"elapsed":60358,"user":{