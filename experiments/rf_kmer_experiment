2: Encoding functions --------------------\n","# Option 1: One-hot encoding\n","def onehot_encode(seq, max_len=None):\n","    mapping = {'A':0, 'C':1, 'G':2, 'T':3}\n","    if max_len is None:\n","        max_len = len(seq)\n","    X = np.zeros((4, max_len), dtype=np.float32)  # channels first\n","    for i, base in enumerate(seq[:max_len]):\n","        if base.upper() in mapping:\n","            X[mapping[base.upper()], i] = 1.0\n","    return X\n","\n","# Option 2: Integer encoding (for embedding)\n","def integer_encode(seq, max_len=None):\n","    mapping = {'A':0, 'C':1, 'G':2, 'T':3}\n","    if max_len is None:\n","        max_len = len(seq)\n","    X = np.zeros(max_len, dtype=np.int64)\n","    for i, base in enumerate(seq[:max_len]):\n","        if base.upper() in mapping:\n","            X[i] = mapping[base.upper()]\n","    return X\n","\n","# Pad/truncate sequences\n","max_len = max(len(seq) for seq in sequences)\n","print(f\"Max sequence length: {max_len}\")\n","\n","# Choose encoding type: 'onehot' or 'embedding'\n","encoding_type = 'embedding'  # change to 'onehot' to try one-hot CNN\n","\n","if encoding_type == 'onehot':\n","    X = np.array([onehot_encode(seq, max_len) for seq in sequences], dtype=np.float32)\n","elif encoding_type == 'embedding':\n","    X = np.array([integer_encode(seq, max_len) for seq in sequences], dtype=np.int64)\n","else:\n","    raise ValueError(\"Unsupported encoding_type\")\n","\n","# -------------------- Step 3: Train/test split --------------------\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# Convert to torch tensors\n","if encoding_type == 'onehot':\n","    X_train_tensor = torch.tensor(X_train, dtype=torch.float32).to(device)\n","    X_test_tensor  = torch.tensor(X_test, dtype=torch.float32).to(device)\n","elif encoding_type == 'embedding':\n","    X_train_tensor = torch.tensor(X_train, dtype=torch.long).to(device)\n","    X_test_tensor  = torch.tensor(X_test, dtype=torch.long).to(device)\n","\n","y_train_tensor = torch.tensor(y_train.reshape(-1,1), dtype=torch.float32).to(device)\n","y_test_tensor  = torch.tensor(y_test.reshape(-1,1), dtype=torch.float32).to(device)\n","\n","# -------------------- Step 4: Define deep 1D CNN --------------------\n","class DeepCNNOneHot(nn.Module):\n","    def __init__(self, seq_len, channels=4):\n","        super(DeepCNNOneHot, self).__init__()\n","        self.net = nn.Sequential(\n","            nn.Conv1d(channels, 128, kernel_size=7, padding=3),\n","            nn.BatchNorm1d(128),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.3),\n","\n","            nn.Conv1d(128, 256, kernel_size=5, padding=2),\n","            nn.BatchNorm1d(256),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.3),\n","\n","            nn.Conv1d(256, 512, kernel_size=3, padding=1),\n","            nn.BatchNorm1d(512),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.2),\n","\n","            nn.Flatten(),\n","            nn.Linear((seq_len // 8) * 512, 256),\n","            nn.ReLU(),\n","            nn.Dropout(0.3),\n","            nn.Linear(256, 1),\n","            nn.Sigmoid()\n","        )\n","\n","    def forward(self, x):\n","        return self.net(x)\n","\n","class DeepCNNEmbedding(nn.Module):\n","    def __init__(self, seq_len, vocab_size=4, embed_dim=16):\n","        super(DeepCNNEmbedding, self).__init__()\n","        self.embedding = nn.Embedding(vocab_size, embed_dim)\n","        self.conv = nn.Sequential(\n","            nn.Conv1d(embed_dim, 128, kernel_size=7, padding=3),\n","            nn.BatchNorm1d(128),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.3),\n","\n","            nn.Conv1d(128, 256, kernel_size=5, padding=2),\n","            nn.BatchNorm1d(256),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.3),\n","\n","            nn.Conv1d(256, 512, kernel_size=3, padding=1),\n","            nn.BatchNorm1d(512),\n","            nn.ReLU(),\n","            nn.MaxPool1d(2),\n","            nn.Dropout(0.2),\n","\n","            nn.Flatten(),\n","            nn.Linear((seq_len // 8) * 512, 256),\n","            nn.ReLU(),\n","            nn.Dropout(0.3),\n","            nn.Linear(256, 1),\n","            nn.Sigmoid()\n","        )\n","\n","    def forward(self, x):\n","        x = self.embedding(x).permute(0,2,1)  # (batch, embed_dim, seq_len)\n","        return self.conv(x)\n","\n","# Instantiate model\n","if encoding_type == 'onehot':\n","    model = DeepCNNOneHot(seq_len=max_len, channels=4).to(device)\n","elif encoding_type == 'embedding':\n","    model = DeepCNNEmbedding(seq_len=max_len, vocab_size=4, embed_dim=16).to(device)\n","\n","criterion = nn.BCELoss()\n","optimizer = optim.Adam(model.parameters(), lr=0.001)\n","\n","# -------------------- Step 5: Train CNN --------------------\n","epochs = 50\n","batch_size = 128\n","n_batches = int(np.ceil(X_train_tensor.shape[0] / batch_size))\n","\n","for epoch in range(epochs):\n","    model.train()\n","    perm = torch.randperm(X_train_tensor.size(0))\n","    epoch_loss = 0\n","    for i in range(n_batches):\n","        idx = perm[i*batch_size:(i+1)*batch_size]\n","        batch_X = X_train_tensor[idx]\n","        batch_y = y_train_tensor[idx]\n","\n","        optimizer.zero_grad()\n","        outputs = model(batch_X)\n","        loss = criterion(outputs, batch_y)\n","        loss.backward()\n","        optimizer.step()\n","        epoch_loss += loss.item() * batch_X.size(0)\n","\n","    epoch_loss /= X_train_tensor.size(0)\n","    if (epoch+1) % 5 == 0:\n","        print(f\"Epoch {epoch+1}/{epochs}, Loss: {epoch_loss:.4f}\")\n","\n","# -------------------- Step 6: Evaluate --------------------\n","model.eval()\n","with torch.no_grad():\n","    y_pred_prob = model(X_test_tensor).cpu().nump